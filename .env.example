# CloudSentinel environment — copy to .env and fill in. Never commit the real
# .env (it is gitignored). Every value below is optional; the shown default
# applies when the variable is unset.

# --- LLM provider ------------------------------------------------------------
# Gemini API key from a billing-disabled Google Cloud project (free tier).
# Get one at https://aistudio.google.com/apikey.
GEMINI_API_KEY=
# Force the deterministic fake provider (tests/CI/offline demos). 1/true/yes/on.
SENTINEL_FAKE_LLM=
# Hard per-call transport timeout in seconds (default 30).
SENTINEL_LLM_TIMEOUT_SECONDS=

# --- persistence -------------------------------------------------------------
# SQLite file path (default cloudsentinel.db). Deploy disks are ephemeral;
# the schema rebuilds on every boot (seed-on-startup).
SENTINEL_DB_PATH=
# Hours before an undecided proposal auto-expires on read (default 72; 0 off).
SENTINEL_ACTION_TTL_HOURS=

# --- detection ---------------------------------------------------------------
# zscore (default) | mad
SENTINEL_DETECTOR=
# Rolling baseline window in days (default 28).
SENTINEL_BASELINE_WINDOW_DAYS=
# 1 to opt into day-of-week (seasonal) baselines (default off).
SENTINEL_SEASONAL=

# --- pulse / guardrails ------------------------------------------------------
# Max provider calls per pulse before rule-based fallback (default 8).
SENTINEL_PULSE_LLM_BUDGET=
# Per-IP POST /pulse limit per minute (default 60; 0 disables).
SENTINEL_PULSE_RATE_LIMIT_PER_MINUTE=

# --- analytics / deploy ------------------------------------------------------
# Monthly cost budget; when set, the forecast flags projected overruns.
SENTINEL_MONTHLY_BUDGET=
# Deploy environment label. Set to "render" to light the LIVE banner.
SENTINEL_ENV=
